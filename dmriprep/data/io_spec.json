{
  "queries": {
    "baseline": {
      "hmc": {
        "datatype": "dwi",
        "space": null,
        "desc": "hmc",
        "suffix": "dwiref",
        "extension": [".nii.gz", ".nii"]
      },
      "coreg": {
        "datatype": "dwi",
        "space": null,
        "desc": "coreg",
        "suffix": "dwiref",
        "extension": [".nii.gz", ".nii"]
      },
      "mask": {
        "datatype": "dwi",
        "space": null,
        "desc": "brain",
        "suffix": "mask",
        "extension": [".nii.gz", ".nii"]
      }
    },
    "gradients": {
      "bvec": {
        "datatype": "dwi",
        "suffix": "dwi",
        "extension": ".bvec"
      },
      "bval": {
        "datatype": "dwi",
        "suffix": "dwi",
        "extension": ".bval"
      }
    },
    "transforms": {
      "hmc": {
        "datatype": "dwi",
        "from": "orig",
        "to": "dwiref",
        "mode": "image",
        "suffix": "xfm",
        "extension": ".txt"
      },
      "dwiref2anat": {
        "datatype": "dwi",
        "from": "dwiref",
        "to": ["anat", "T1w", "T2w"],
        "mode": "image",
        "suffix": "xfm",
        "extension": ".txt"
      },
      "dwiref2fmap": {
        "datatype": "dwi",
        "from": "dwiref",
        "mode": "image",
        "suffix": "xfm",
        "extension": ".txt"
      }
    },
    "fieldmap": {
      "fmap_coeff": {
        "datatype": "dwi",
        "suffix": "fieldcoeff",
        "extension": [".nii.gz", ".nii"]
      }
    }
  },
  "patterns": [
    "sub-{subject}[/ses-{session}]/{datatype<dwi>|dwi}/sub-{subject}[_ses-{session}][_task-{task}][_acq-{acquisition}][_ce-{ceagent}][_rec-{reconstruction}][_dir-{direction}][_run-{run}][_res-{res}][_label-{label}][_echo-{echo}][_space-{space}][_desc-{desc}]_{suffix<dwi>|dwi}.{extension<nii|nii.gz|json|bvec|bval>|nii.gz}",
    "sub-{subject}[/ses-{session}]/{datatype<dwi>|dwi}/sub-{subject}[_ses-{session}][_task-{task}][_acq-{acquisition}][_ce-{ceagent}][_rec-{reconstruction}][_dir-{direction}][_run-{run}][_res-{res}][_label-{label}][_echo-{echo}][_space-{space}][_desc-{desc}]_{suffix<dwiref|dseg|mask>}.{extension<nii|nii.gz|json>|nii.gz}",
    "sub-{subject}[/ses-{session}]/{datatype<dwi>|dwi}/sub-{subject}[_ses-{session}][_task-{task}][_acq-{acquisition}][_ce-{ceagent}][_rec-{reconstruction}][_dir-{direction}][_run-{run}]_from-{from}_to-{to}_mode-{mode<image|points>|image}_{suffix<xfm>|xfm}.{extension<txt|h5>}",
    "sub-{subject}[/ses-{session}]/{datatype<dwi>|dwi}/sub-{subject}[_ses-{session}][_task-{task}][_acq-{acquisition}][_ce-{ceagent}][_rec-{reconstruction}][_dir-{direction}][_run-{run}][_part-{part}][_desc-{desc}]_{suffix<timeseries|motion>}.{extension<tsv|json>}",
    "sub-{subject}[/ses-{session}]/{datatype<dwi>|dwi}/sub-{subject}[_ses-{session}][_task-{task}][_acq-{acquisition}][_ce-{ceagent}][_rec-{reconstruction}][_space-{space}][_res-{res}][_den-{den}][_hemi-{hemi}][_label-{label}][_desc-{desc}]_{suffix<dwiref|dseg|mask>}.{extension<dtseries.nii|dtseries.json>}",
    "sub-{subject}[/ses-{session}]/{datatype<dwi>|dwi}/sub-{subject}[_ses-{session}][_task-{task}][_acq-{acquisition}][_ce-{ceagent}][_rec-{reconstruction}][_dir-{direction}][_run-{run}][_desc-{desc}]_{suffix<fieldcoeff>}.{extension<nii|nii.gz>|nii.gz}"
  ]
}
